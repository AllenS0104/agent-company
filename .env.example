# LLM Provider API Keys
# 至少配置一个

# ═══════════════════════════════════════════════
# 推荐：GitHub Models API（通过 gh CLI 账号认证）
# ═══════════════════════════════════════════════
# Token 会自动从 `gh auth token` 获取，无需手动填写
# 前提：已运行 `gh auth login` 完成登录
# GITHUB_TOKEN=               # 可选，手动指定则优先使用
GITHUB_MODELS_MODEL=openai/gpt-4.1

# ═══════════════════════════════════════════════
# 可选：其他 Provider
# ═══════════════════════════════════════════════

# OpenAI
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4.1
# OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini
# GEMINI_API_KEY=your-key-here
# GEMINI_MODEL=gemini-3.1-flash

# Anthropic Claude
# CLAUDE_API_KEY=your-key-here
# CLAUDE_MODEL=claude-sonnet-4.6

# ═══════════════════════════════════════════════
# GitHub OAuth (可选，用于 "Login with GitHub" 功能)
# 创建 OAuth App: https://github.com/settings/developers
# ═══════════════════════════════════════════════
GITHUB_CLIENT_ID=

# 默认 Provider (github / openai / gemini / claude)
DEFAULT_LLM_PROVIDER=github

# 讨论设置
MAX_DISCUSSION_ROUNDS=3
MAX_MESSAGE_LENGTH=2000

# 日志级别
LOG_LEVEL=INFO
